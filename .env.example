# RailMind Environment Variables
# Copy this to .env and fill in your values.
# Get an OpenAI API key at https://platform.openai.com/api-keys

# LLM Provider (optional — without it, rule-based fallback is used)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database (defaults to local postgres if unset)
# For Supabase: postgresql+psycopg2://<user>:<password>@<host>:6543/<db>?sslmode=require
DATABASE_URL=
